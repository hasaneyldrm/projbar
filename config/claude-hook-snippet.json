{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Read|MultiEdit|NotebookEdit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/projbar-hook",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/projbar-session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
